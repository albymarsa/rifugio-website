---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import BookingForm from '../components/BookingForm.astro';
import CalendarioDisponibilita from '../components/CalendarioDisponibilita.astro';
import { createClient } from '@supabase/supabase-js';

const user = Astro.locals.user;

// Carica profilo utente
let profilo: any = null;
if (user) {
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const accessToken = Astro.cookies.get('sb-access-token')?.value;
  const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

  if (accessToken && refreshToken) {
    await supabase.auth.setSession({
      access_token: accessToken,
      refresh_token: refreshToken,
    });
  }

  const { data } = await supabase.from('profili').select('*').eq('id', user.id).single();
  profilo = data;
}
---

<Layout title="Prenota — Rifugio Alpine">
  <section class="page-header">
    <div class="container">
      <span class="section-label">Prenotazioni</span>
      <h1>Prenota la struttura</h1>
      <p class="page-header__desc">
        La struttura è prenotabile esclusivamente nella sua interezza (25 posti letto).
        Compila il modulo qui sotto per richiedere una prenotazione.
        Ti confermeremo la disponibilità via email entro 48 ore.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {profilo ? (
        <>
          <CalendarioDisponibilita />
          <BookingForm profilo={profilo} />
        </>
      ) : (
        <div class="booking-no-profile">
          <p>Per richiedere una prenotazione devi prima completare il tuo profilo.</p>
          <a href="/soci/" class="btn btn-primary">Vai alla dashboard</a>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  .page-header {
    padding-top: calc(64px + 4rem);
    padding-bottom: 2rem;
    background-color: var(--color-off-white);
  }

  .page-header h1 {
    margin-bottom: 1rem;
  }

  .page-header__desc {
    font-size: 1.1rem;
    color: var(--color-gray);
    max-width: 560px;
  }

  .booking-no-profile {
    padding: 3rem 2rem;
    background: var(--color-off-white);
    text-align: center;
  }

  .booking-no-profile p {
    max-width: none;
    color: var(--color-gray);
    margin-bottom: 1.5rem;
  }
</style>
