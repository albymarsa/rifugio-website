---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';
import AuthForm from '../../components/soci/AuthForm.astro';

// Se l'utente e' gia' loggato, redirect alla dashboard
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  return Astro.redirect('/soci/');
}
---

<SociLayout title="Accedi" showBackLink={false}>
  <div class="login-page">
    <div class="section-label">Area Soci</div>
    <h1 class="section-title">Accedi</h1>
    <p class="login-page__intro">
      Accedi con il tuo account per visualizzare e gestire i tuoi dati di socio.
    </p>
    <AuthForm mode="login" />
  </div>
</SociLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  const form = document.getElementById('auth-form') as HTMLFormElement;
  const errorDiv = document.getElementById('auth-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.hidden = true;

    const formData = new FormData(form);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Accesso in corso...';
    submitBtn.disabled = true;

    const { data, error } = await supabase.auth.signInWithPassword({
      email,
      password,
    });

    if (error) {
      errorDiv.textContent = error.message === 'Invalid login credentials'
        ? 'Email o password non corretti.'
        : 'Errore durante l\'accesso. Riprova.';
      errorDiv.hidden = false;
      submitBtn.textContent = 'Accedi';
      submitBtn.disabled = false;
      return;
    }

    if (data.session) {
      // Salva i token nei cookie
      document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=3600; SameSite=Lax`;
      document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; max-age=604800; SameSite=Lax`;
      window.location.href = '/soci/';
    }
  });
</script>

<style>
  .login-page {
    max-width: 440px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .login-page__intro {
    margin-bottom: 2.5rem;
    color: var(--color-gray);
  }
</style>
