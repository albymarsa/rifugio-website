---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';
import MemberCard from '../../components/soci/MemberCard.astro';
import MemberForm from '../../components/soci/MemberForm.astro';
import PrenotazioneCard from '../../components/soci/PrenotazioneCard.astro';
import { createClient } from '@supabase/supabase-js';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/soci/login');
}

// Crea client con la sessione dell'utente
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

let sessionError = null;
if (accessToken && refreshToken) {
  const { error: sessErr } = await supabase.auth.setSession({
    access_token: accessToken,
    refresh_token: refreshToken,
  });
  if (sessErr) {
    console.error('[Dashboard] Errore sessione:', sessErr.message);
    sessionError = sessErr;
  }
}

if (sessionError) {
  Astro.cookies.delete('sb-access-token', { path: '/' });
  Astro.cookies.delete('sb-refresh-token', { path: '/' });
  return Astro.redirect('/soci/login');
}

// Carica profilo utente
const { data: profilo } = await supabase.from('profili').select('*').eq('id', user.id).single();

// Carica i soci registrati dall'utente
let members: any[] = [];
let error: any = null;
let errorMessage = '';

const result = await supabase
  .from('soci')
  .select('*')
  .eq('registrato_da', user.id)
  .order('created_at');

members = result.data || [];
error = result.error;
if (error) {
  console.error('[Dashboard] Errore query soci:', error.message, error.code, error.details);
  errorMessage = error.message;
}

// Verifica se l'utente e' un fondatore
const isFounder = members?.some((m: any) => m.tipo_socio === 'fondatore' && m.email === user.email);

// Carica le prenotazioni: quelle create dall'utente + quelle associate ai soci del gruppo
const memberIds = members.map((m: any) => m.id);
let prenotazioni: any[] = [];
let prenotazioniPartecipanti: Record<string, any[]> = {};

// Prenotazioni create dall'utente
const { data: prenCreate } = await supabase
  .from('prenotazioni')
  .select('*')
  .eq('creata_da', user.id)
  .order('data_arrivo', { ascending: false });

const prenotazioniCreate = prenCreate || [];
const prenIdsFromCreate = prenotazioniCreate.map((p: any) => p.id);

// Prenotazioni associate via soci del gruppo
let prenIdsFromSoci: string[] = [];
if (memberIds.length > 0) {
  const { data: associazioni } = await supabase
    .from('prenotazioni_soci')
    .select('prenotazione_id, socio_id')
    .in('socio_id', memberIds);

  if (associazioni && associazioni.length > 0) {
    prenIdsFromSoci = [...new Set(associazioni.map((a: any) => a.prenotazione_id))];

    // Carica prenotazioni associate non già caricate
    const missingIds = prenIdsFromSoci.filter((id: string) => !prenIdsFromCreate.includes(id));
    if (missingIds.length > 0) {
      const { data: prenExtra } = await supabase
        .from('prenotazioni')
        .select('*')
        .in('id', missingIds);
      if (prenExtra) prenotazioniCreate.push(...prenExtra);
    }

    // Mappa partecipanti
    for (const pren of prenotazioniCreate) {
      const sociIds = associazioni
        .filter((a: any) => a.prenotazione_id === pren.id)
        .map((a: any) => a.socio_id);
      prenotazioniPartecipanti[pren.id] = members.filter((m: any) => sociIds.includes(m.id));
    }
  }
}

// Ordina per data arrivo desc
prenotazioni = prenotazioniCreate.sort((a: any, b: any) =>
  new Date(b.data_arrivo).getTime() - new Date(a.data_arrivo).getTime()
);

function getSociDisponibili(prenotazioneId: string) {
  const giAssociati = (prenotazioniPartecipanti[prenotazioneId] || []).map((p: any) => p.id);
  return members.filter((m: any) => !giAssociati.includes(m.id));
}

// Dati profilo per il bottone "Usa i miei dati"
const profiloDati = profilo ? {
  nome: profilo.nome || '',
  cognome: profilo.cognome || '',
  email: profilo.email || '',
  telefono: profilo.telefono || '',
} : null;
---

<SociLayout title="Dashboard" showBackLink={false}>
  <div class="dashboard">
    <div class="dashboard__header">
      <div>
        <div class="section-label">Area Personale</div>
        <h1 class="section-title">
          {profilo ? `Ciao, ${profilo.nome}` : 'La tua dashboard'}
        </h1>
      </div>
      <div class="dashboard__header-actions">
        {isFounder && (
          <>
            <a href="/soci/admin" class="btn btn-outline">
              Gestione soci
            </a>
            <a href="/soci/prenotazioni" class="btn btn-outline">
              Gestione prenotazioni
            </a>
          </>
        )}
      </div>
    </div>

    {error && (
      <div class="alert alert--error">
        Errore nel caricamento dei dati: {errorMessage || 'Errore sconosciuto'}
      </div>
    )}

    {!profilo && (
      <div class="dashboard__empty">
        <p>Completa il tuo profilo per poter richiedere prenotazioni.</p>
        <a href="/soci/registrazione" class="btn btn-primary mt-2">Completa profilo</a>
      </div>
    )}

    <!-- Sezione Soci -->
    <div class="dashboard__section">
      <h2 class="dashboard__subtitle">I tuoi soci</h2>

      {members.length === 0 ? (
        <div class="dashboard__empty">
          <p>Non hai ancora soci registrati nel tuo gruppo.</p>
          <p>Iscriviti come socio o aggiungi i componenti del tuo gruppo.</p>
        </div>
      ) : (
        <div id="members-container">
          {members.map((member) => (
            <div class="member-wrapper" data-member-id={member.id}>
              <div class="member-view">
                <MemberCard member={member} />
              </div>
            </div>
          ))}
        </div>
      )}

      <!-- Bottone aggiungi componente -->
      <div class="dashboard__actions">
        <button id="add-member-btn" class="btn btn-outline">
          + Aggiungi socio
        </button>
      </div>

      <!-- Form nuovo componente -->
      <div id="new-member-container" hidden>
        <h2 class="dashboard__subtitle">Nuovo socio</h2>
        {profiloDati && (
          <>
            <button id="use-my-data-btn" class="btn btn-outline dashboard__use-data-btn">
              Usa i miei dati
            </button>
            <input type="hidden" id="profilo-prefill-nome" value={profiloDati.nome} />
            <input type="hidden" id="profilo-prefill-cognome" value={profiloDati.cognome} />
            <input type="hidden" id="profilo-prefill-email" value={profiloDati.email} />
            <input type="hidden" id="profilo-prefill-telefono" value={profiloDati.telefono} />
          </>
        )}
        <MemberForm formId="new-member-form" submitLabel="Aggiungi" showCancel={true} />
      </div>
    </div>

    <!-- Sezione Prenotazioni -->
    <div class="dashboard__prenotazioni">
      <div class="dashboard__pren-header">
        <h2 class="dashboard__subtitle">Le tue prenotazioni</h2>
        {profilo && (
          <a href="/prenota" class="btn btn-outline dashboard__pren-btn">
            + Nuova prenotazione
          </a>
        )}
      </div>
      {prenotazioni.length === 0 ? (
        <div class="dashboard__empty">
          <p>Non hai prenotazioni.</p>
        </div>
      ) : (
        <div id="prenotazioni-container">
          {prenotazioni.map((pren) => (
            <PrenotazioneCard
              prenotazione={pren}
              partecipanti={prenotazioniPartecipanti[pren.id] || []}
              sociDisponibili={getSociDisponibili(pren.id)}
            />
          ))}
        </div>
      )}
    </div>

    <!-- Sezione Account -->
    <div class="dashboard__account">
      <h2 class="dashboard__subtitle">Il tuo account</h2>
      <p class="dashboard__account-desc">
        Gestisci i tuoi dati personali in conformità con il GDPR.
      </p>
      <div class="dashboard__account-actions">
        <button id="download-data-btn" class="btn btn-outline">
          Scarica i miei dati
        </button>
        <button id="delete-account-btn" class="btn btn-danger">
          Elimina account
        </button>
      </div>
      <div id="account-message" class="dashboard__account-msg" hidden></div>
    </div>
  </div>
</SociLayout>

<script>
  // === Aggiungi nuovo socio ===
  const addBtn = document.getElementById('add-member-btn')!;
  const newContainer = document.getElementById('new-member-container')!;
  const newForm = document.getElementById('new-member-form') as HTMLFormElement;

  addBtn.addEventListener('click', () => {
    newContainer.hidden = false;
    addBtn.hidden = true;
    newContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  newForm.querySelector('[data-cancel]')?.addEventListener('click', () => {
    newContainer.hidden = true;
    addBtn.hidden = false;
    newForm.reset();
  });

  // === Usa i miei dati ===
  const useMyDataBtn = document.getElementById('use-my-data-btn');
  if (useMyDataBtn) {
    useMyDataBtn.addEventListener('click', () => {
      const setVal = (targetId: string, sourceId: string) => {
        const target = document.getElementById(targetId) as HTMLInputElement;
        const source = document.getElementById(sourceId) as HTMLInputElement;
        if (target && source?.value) target.value = source.value;
      };
      setVal('new-member-form-nome', 'profilo-prefill-nome');
      setVal('new-member-form-cognome', 'profilo-prefill-cognome');
      setVal('new-member-form-email', 'profilo-prefill-email');
      setVal('new-member-form-telefono', 'profilo-prefill-telefono');
      useMyDataBtn.hidden = true;
    });
  }

  newForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!newForm.checkValidity()) {
      newForm.reportValidity();
      return;
    }

    const submitBtn = newForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Salvataggio...';
    submitBtn.disabled = true;

    const formData = new FormData(newForm);
    const msgEl = newForm.querySelector('[data-message]') as HTMLElement;

    try {
      const res = await fetch('/api/soci', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          nome: formData.get('nome'),
          cognome: formData.get('cognome'),
          email: formData.get('email'),
          telefono: formData.get('telefono') || null,
          data_nascita: formData.get('data_nascita') || null,
          luogo_nascita: formData.get('luogo_nascita') || null,
          codice_fiscale: formData.get('codice_fiscale') || null,
          indirizzo_residenza: formData.get('indirizzo_residenza') || null,
          tipo_documento: formData.get('tipo_documento') || null,
          numero_documento: formData.get('numero_documento') || null,
        }),
      });

      const result = await res.json();

      if (!res.ok) {
        msgEl.textContent = result.error || 'Errore nel salvataggio.';
        msgEl.setAttribute('data-type', 'error');
        msgEl.hidden = false;
        submitBtn.textContent = 'Aggiungi';
        submitBtn.disabled = false;
        return;
      }

      window.location.reload();
    } catch {
      msgEl.textContent = 'Errore di connessione. Riprova.';
      msgEl.setAttribute('data-type', 'error');
      msgEl.hidden = false;
      submitBtn.textContent = 'Aggiungi';
      submitBtn.disabled = false;
    }
  });

  // === Modifica socio ===
  document.querySelectorAll('[data-edit]').forEach((btn) => {
    btn.addEventListener('click', () => {
      alert('Funzionalita\' di modifica in arrivo. Per ora contatta un fondatore per modifiche.');
    });
  });

  // === Aggiungi partecipante a prenotazione ===
  document.querySelectorAll('[data-toggle-add]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const prenId = (btn as HTMLElement).getAttribute('data-toggle-add')!;
      const form = document.querySelector(`[data-add-form="${prenId}"]`) as HTMLElement;
      if (form) {
        form.hidden = !form.hidden;
        (btn as HTMLElement).hidden = !form.hidden;
      }
    });
  });

  document.querySelectorAll('[data-confirm-add]').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const prenId = (btn as HTMLElement).getAttribute('data-confirm-add')!;
      const select = document.querySelector(`[data-add-select="${prenId}"]`) as HTMLSelectElement;
      const socioId = select?.value;

      if (!socioId) return;

      try {
        const res = await fetch('/api/prenotazioni-soci', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ prenotazione_id: prenId, socio_id: socioId }),
        });

        if (!res.ok) {
          const result = await res.json();
          alert(result.error || 'Errore nell\'aggiunta del partecipante.');
          return;
        }

        window.location.reload();
      } catch {
        alert('Errore di connessione. Riprova.');
      }
    });
  });

  // === Scarica i miei dati ===
  const downloadBtn = document.getElementById('download-data-btn');
  if (downloadBtn) {
    downloadBtn.addEventListener('click', async () => {
      (downloadBtn as HTMLButtonElement).textContent = 'Caricamento...';
      (downloadBtn as HTMLButtonElement).disabled = true;

      try {
        const res = await fetch('/api/account/data');
        if (!res.ok) {
          alert('Errore nel download dei dati. Riprova.');
          return;
        }

        const blob = await res.blob();
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = 'i-miei-dati.json';
        a.click();
        URL.revokeObjectURL(url);
      } catch {
        alert('Errore di connessione. Riprova.');
      } finally {
        (downloadBtn as HTMLButtonElement).textContent = 'Scarica i miei dati';
        (downloadBtn as HTMLButtonElement).disabled = false;
      }
    });
  }

  // === Elimina account ===
  const deleteBtn = document.getElementById('delete-account-btn');
  if (deleteBtn) {
    deleteBtn.addEventListener('click', async () => {
      const confirmed = confirm(
        'Sei sicuro di voler eliminare il tuo account?\n\n' +
        'Questa azione è irreversibile e comporterà la cancellazione di:\n' +
        '- Il tuo account e profilo\n' +
        '- Tutti i soci registrati da te\n' +
        '- Tutte le tue prenotazioni\n\n' +
        'Ti consigliamo di scaricare i tuoi dati prima di procedere.'
      );

      if (!confirmed) return;

      const doubleConfirm = confirm(
        'Conferma definitiva: vuoi davvero eliminare il tuo account e tutti i dati associati?'
      );

      if (!doubleConfirm) return;

      (deleteBtn as HTMLButtonElement).textContent = 'Eliminazione...';
      (deleteBtn as HTMLButtonElement).disabled = true;

      try {
        const res = await fetch('/api/account/delete', { method: 'DELETE' });
        const result = await res.json();

        if (!res.ok) {
          alert(result.error || 'Errore nell\'eliminazione dell\'account.');
          (deleteBtn as HTMLButtonElement).textContent = 'Elimina account';
          (deleteBtn as HTMLButtonElement).disabled = false;
          return;
        }

        alert('Account eliminato con successo.');
        window.location.href = '/';
      } catch {
        alert('Errore di connessione. Riprova.');
        (deleteBtn as HTMLButtonElement).textContent = 'Elimina account';
        (deleteBtn as HTMLButtonElement).disabled = false;
      }
    });
  }
</script>

<style>
  .dashboard {
    padding-top: 1rem;
  }

  .dashboard__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .dashboard__header-actions {
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .dashboard__section {
    margin-bottom: 2rem;
  }

  .dashboard__empty {
    padding: 3rem 2rem;
    background: var(--color-off-white);
    text-align: center;
    margin-bottom: 2rem;
  }

  .dashboard__empty p {
    max-width: none;
    color: var(--color-gray);
    margin-bottom: 0.5rem;
  }

  .dashboard__actions {
    margin-top: 1rem;
    margin-bottom: 2rem;
  }

  .dashboard__subtitle {
    font-size: 1.3rem;
    margin-bottom: 1.5rem;
  }

  .dashboard__use-data-btn {
    padding: 0.5rem 1.2rem;
    font-size: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .dashboard__prenotazioni {
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
  }

  .dashboard__pren-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .dashboard__pren-header .dashboard__subtitle {
    margin-bottom: 0;
  }

  .dashboard__pren-btn {
    padding: 0.5rem 1.2rem;
    font-size: 0.75rem;
  }

  .alert--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .dashboard__account {
    margin-top: 1rem;
    padding-top: 2rem;
    border-top: 2px solid var(--color-border);
  }

  .dashboard__account-desc {
    font-size: 0.9rem;
    color: var(--color-gray);
    margin-bottom: 1.5rem;
    max-width: none;
  }

  .dashboard__account-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .dashboard__account-msg {
    margin-top: 1rem;
    padding: 1rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
  }
</style>
