---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';

// Se l'utente e' gia' loggato, redirect alla dashboard
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  return Astro.redirect('/soci/');
}
---

<SociLayout title="Registrazione" showBackLink={false}>
  <div class="register-page">
    <div class="section-label">Area Personale</div>
    <h1 class="section-title">Registrazione</h1>
    <p class="register-page__intro">
      Crea un account per iscriverti al sito. Potrai poi iscriverti come socio e richiedere prenotazioni.
    </p>

    <form id="register-form" class="register-form" novalidate>
      <div class="form-row">
        <div class="form-group">
          <label for="reg-nome">Nome *</label>
          <input type="text" id="reg-nome" name="nome" required autocomplete="given-name" />
        </div>
        <div class="form-group">
          <label for="reg-cognome">Cognome *</label>
          <input type="text" id="reg-cognome" name="cognome" required autocomplete="family-name" />
        </div>
      </div>

      <div class="form-group">
        <label for="reg-email">Email *</label>
        <input type="email" id="reg-email" name="email" required autocomplete="email" />
      </div>

      <div class="form-group">
        <label for="reg-telefono">Telefono</label>
        <input type="tel" id="reg-telefono" name="telefono" autocomplete="tel" />
      </div>

      <div class="form-group">
        <label for="reg-password">Password *</label>
        <input type="password" id="reg-password" name="password" required minlength="6" autocomplete="new-password" />
        <span class="form-hint">Minimo 6 caratteri</span>
      </div>

      <div class="form-group">
        <label for="reg-password-confirm">Conferma password *</label>
        <input type="password" id="reg-password-confirm" name="password_confirm" required minlength="6" autocomplete="new-password" />
      </div>

      <div class="form-group form-group--checkbox">
        <label class="checkbox-label">
          <input type="checkbox" id="reg-privacy" name="privacy_consent" required />
          <span>
            Ho letto l'<a href="/privacy" target="_blank">informativa sulla privacy</a> e acconsento al trattamento dei dati personali. *
          </span>
        </label>
      </div>

      <button type="submit" class="btn btn-primary register-form__submit">
        Crea account
      </button>

      <div id="register-error" class="form-message form-message--error" hidden></div>
      <div id="register-success" class="form-message form-message--success" hidden></div>

      <div class="register-form__footer">
        <p>Hai già un account? <a href="/soci/login">Accedi</a></p>
      </div>
    </form>
  </div>
</SociLayout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorDiv = document.getElementById('register-error')!;
  const successDiv = document.getElementById('register-success')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.hidden = true;
    successDiv.hidden = true;

    const formData = new FormData(form);
    const nome = formData.get('nome') as string;
    const cognome = formData.get('cognome') as string;
    const email = formData.get('email') as string;
    const telefono = formData.get('telefono') as string;
    const password = formData.get('password') as string;
    const passwordConfirm = formData.get('password_confirm') as string;

    if (password !== passwordConfirm) {
      errorDiv.textContent = 'Le password non coincidono.';
      errorDiv.hidden = false;
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Registrazione in corso...';
    submitBtn.disabled = true;

    try {
      const res = await fetch('/api/auth/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password, nome, cognome, telefono: telefono || null }),
      });

      const result = await res.json();

      if (!res.ok) {
        errorDiv.textContent = result.error || 'Errore nella registrazione.';
        errorDiv.hidden = false;
        submitBtn.textContent = 'Crea account';
        submitBtn.disabled = false;
        return;
      }

      if (result.needsEmailConfirm) {
        successDiv.innerHTML = 'Account creato! Controlla la tua casella email (anche la cartella spam) per confermare l\'account, poi <a href="/soci/login">accedi</a>.';
        successDiv.hidden = false;
        submitBtn.textContent = 'Crea account';
        submitBtn.disabled = false;
      } else {
        window.location.href = '/soci/';
      }
    } catch {
      errorDiv.textContent = 'Errore di connessione. Riprova.';
      errorDiv.hidden = false;
      submitBtn.textContent = 'Crea account';
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .register-page {
    max-width: 500px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .register-page__intro {
    margin-bottom: 2.5rem;
    color: var(--color-gray);
  }

  .register-form__submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .register-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .register-form__footer {
    margin-top: 2rem;
    text-align: center;
  }

  .register-form__footer p {
    font-size: 0.9rem;
    color: var(--color-gray);
    max-width: none;
  }

  .register-form__footer a {
    color: var(--color-black);
    font-weight: 600;
    text-decoration: underline;
  }

  .form-hint {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.8rem;
    color: var(--color-gray);
  }

  .form-message {
    margin-top: 1.5rem;
    padding: 1.2rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .form-message--success {
    background-color: #f0f7ec;
    color: #2d5016;
    border-left: 3px solid #2d5016;
  }

  .form-message--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
  }

  .form-group--checkbox {
    margin-top: 0.5rem;
  }

  .checkbox-label {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-dark);
    cursor: pointer;
    text-transform: none;
    letter-spacing: normal;
    font-weight: 400;
  }

  .checkbox-label input[type="checkbox"] {
    margin-top: 0.25rem;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
  }

  .checkbox-label a {
    color: var(--color-black);
    font-weight: 600;
    text-decoration: underline;
  }
</style>
