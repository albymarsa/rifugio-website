---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';
import AuthForm from '../../components/soci/AuthForm.astro';
import MemberForm from '../../components/soci/MemberForm.astro';

// Se l'utente e' gia' loggato, redirect alla dashboard
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  return Astro.redirect('/soci/');
}
---

<SociLayout title="Registrazione" showBackLink={false}>
  <div class="register-page">
    <div class="section-label">Area Soci</div>
    <h1 class="section-title">Registrazione</h1>
    <p class="register-page__intro">
      Crea un account per iscriverti come socio. Potrai anche registrare i componenti del tuo gruppo.
    </p>

    <!-- Step 1: Crea account -->
    <div id="step-account" class="register-step">
      <h2 class="register-step__title">1. Crea il tuo account</h2>
      <AuthForm mode="register" />
    </div>

    <!-- Step 2: Dati personali -->
    <div id="step-data" class="register-step" hidden>
      <h2 class="register-step__title">2. I tuoi dati personali</h2>
      <p class="register-step__desc">
        Inserisci i tuoi dati per completare l'iscrizione come socio.
      </p>
      <MemberForm formId="self-member-form" submitLabel="Salva e continua" />
    </div>

    <!-- Step 3: Componenti del gruppo -->
    <div id="step-group" class="register-step" hidden>
      <div class="register-step__success">
        <p>I tuoi dati sono stati salvati.</p>
      </div>

      <h2 class="register-step__title">3. Componenti del gruppo (opzionale)</h2>
      <p class="register-step__desc">
        Vuoi registrare altri componenti del tuo gruppo? Potrai aggiungerne anche in seguito dalla tua dashboard.
      </p>

      <div id="group-members-list"></div>

      <div id="group-form-container" hidden>
        <h3 class="mt-3">Nuovo componente</h3>
        <MemberForm formId="group-member-form" submitLabel="Aggiungi componente" showCancel={true} />
      </div>

      <div class="register-step__actions">
        <button id="add-group-btn" class="btn btn-outline">
          + Aggiungi componente del gruppo
        </button>
        <a href="/soci/" class="btn btn-primary">
          Vai alla dashboard
        </a>
      </div>
    </div>
  </div>
</SociLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  let currentUserId: string | null = null;

  // === STEP 1: Registrazione account ===
  const authForm = document.getElementById('auth-form') as HTMLFormElement;
  const authError = document.getElementById('auth-error')!;
  const authSuccess = document.getElementById('auth-success')!;

  authForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    authError.hidden = true;
    authSuccess.hidden = true;

    const formData = new FormData(authForm);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const passwordConfirm = formData.get('password_confirm') as string;

    if (password !== passwordConfirm) {
      authError.textContent = 'Le password non coincidono.';
      authError.hidden = false;
      return;
    }

    const submitBtn = authForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Creazione account...';
    submitBtn.disabled = true;

    const { data, error } = await supabase.auth.signUp({ email, password });

    if (error) {
      authError.textContent = 'Errore nella registrazione: ' + error.message;
      authError.hidden = false;
      submitBtn.textContent = 'Crea account';
      submitBtn.disabled = false;
      return;
    }

    if (data.session) {
      // Salva token nei cookie
      document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=3600; SameSite=Lax`;
      document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; max-age=604800; SameSite=Lax`;
      currentUserId = data.user?.id || null;

      // Passa allo step 2
      document.getElementById('step-account')!.hidden = true;
      document.getElementById('step-data')!.hidden = false;

      // Pre-compila l'email
      const emailInput = document.getElementById('self-member-form-email') as HTMLInputElement;
      if (emailInput) emailInput.value = email;
    } else {
      // Se la conferma email e' attiva
      authSuccess.textContent = 'Account creato! Controlla la tua email per confermare, poi accedi.';
      authSuccess.hidden = false;
      submitBtn.textContent = 'Crea account';
      submitBtn.disabled = false;
    }
  });

  // === STEP 2: Dati personali ===
  const selfForm = document.getElementById('self-member-form') as HTMLFormElement;

  selfForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!selfForm.checkValidity()) {
      selfForm.reportValidity();
      return;
    }

    const submitBtn = selfForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Salvataggio...';
    submitBtn.disabled = true;

    const formData = new FormData(selfForm);
    const memberData = {
      nome: formData.get('nome'),
      cognome: formData.get('cognome'),
      email: formData.get('email'),
      telefono: formData.get('telefono') || null,
      data_nascita: formData.get('data_nascita') || null,
      luogo_nascita: formData.get('luogo_nascita') || null,
      codice_fiscale: formData.get('codice_fiscale') || null,
      indirizzo_residenza: formData.get('indirizzo_residenza') || null,
      tipo_documento: formData.get('tipo_documento') || null,
      numero_documento: formData.get('numero_documento') || null,
      registrato_da: currentUserId,
      tipo_socio: 'ordinario',
    };

    const { error } = await supabase.from('soci').insert([memberData]);

    if (error) {
      const msgEl = selfForm.querySelector('[data-message]') as HTMLElement;
      msgEl.textContent = 'Errore nel salvataggio: ' + error.message;
      msgEl.setAttribute('data-type', 'error');
      msgEl.hidden = false;
      submitBtn.textContent = 'Salva e continua';
      submitBtn.disabled = false;
      return;
    }

    // Passa allo step 3
    document.getElementById('step-data')!.hidden = true;
    document.getElementById('step-group')!.hidden = false;
  });

  // === STEP 3: Componenti del gruppo ===
  const addGroupBtn = document.getElementById('add-group-btn')!;
  const groupFormContainer = document.getElementById('group-form-container')!;
  const groupForm = document.getElementById('group-member-form') as HTMLFormElement;
  const groupMembersList = document.getElementById('group-members-list')!;

  addGroupBtn.addEventListener('click', () => {
    groupFormContainer.hidden = false;
    addGroupBtn.hidden = true;
  });

  // Bottone annulla nel form gruppo
  groupForm.querySelector('[data-cancel]')?.addEventListener('click', () => {
    groupFormContainer.hidden = true;
    addGroupBtn.hidden = false;
    groupForm.reset();
  });

  groupForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!groupForm.checkValidity()) {
      groupForm.reportValidity();
      return;
    }

    const submitBtn = groupForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Salvataggio...';
    submitBtn.disabled = true;

    const formData = new FormData(groupForm);
    const memberData = {
      nome: formData.get('nome'),
      cognome: formData.get('cognome'),
      email: formData.get('email'),
      telefono: formData.get('telefono') || null,
      data_nascita: formData.get('data_nascita') || null,
      luogo_nascita: formData.get('luogo_nascita') || null,
      codice_fiscale: formData.get('codice_fiscale') || null,
      indirizzo_residenza: formData.get('indirizzo_residenza') || null,
      tipo_documento: formData.get('tipo_documento') || null,
      numero_documento: formData.get('numero_documento') || null,
      registrato_da: currentUserId,
      tipo_socio: 'ordinario',
    };

    const { error } = await supabase.from('soci').insert([memberData]);

    if (error) {
      const msgEl = groupForm.querySelector('[data-message]') as HTMLElement;
      msgEl.textContent = 'Errore: ' + error.message;
      msgEl.setAttribute('data-type', 'error');
      msgEl.hidden = false;
      submitBtn.textContent = 'Aggiungi componente';
      submitBtn.disabled = false;
      return;
    }

    // Mostra conferma nella lista
    const item = document.createElement('div');
    item.className = 'group-member-added';
    item.textContent = `${memberData.nome} ${memberData.cognome} aggiunto`;
    groupMembersList.appendChild(item);

    // Reset form
    groupForm.reset();
    groupFormContainer.hidden = true;
    addGroupBtn.hidden = false;
    submitBtn.textContent = 'Aggiungi componente';
    submitBtn.disabled = false;
  });
</script>

<style>
  .register-page {
    max-width: 680px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .register-page__intro {
    margin-bottom: 2.5rem;
    color: var(--color-gray);
  }

  .register-step {
    margin-bottom: 3rem;
  }

  .register-step__title {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .register-step__desc {
    color: var(--color-gray);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .register-step__success {
    background-color: #f0f7ec;
    color: #2d5016;
    border-left: 3px solid #2d5016;
    padding: 1rem 1.5rem;
    margin-bottom: 2rem;
    font-weight: 600;
    font-size: 0.95rem;
  }

  .register-step__actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    flex-wrap: wrap;
  }

  :global(.group-member-added) {
    padding: 0.8rem 1.2rem;
    background: var(--color-off-white);
    border-left: 3px solid var(--color-accent);
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-dark);
  }
</style>
