---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';
import AuthForm from '../../components/soci/AuthForm.astro';

// Se l'utente e' gia' loggato, redirect alla dashboard
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  return Astro.redirect('/soci/');
}
---

<SociLayout title="Registrazione" showBackLink={false}>
  <div class="register-page">
    <div class="section-label">Area Personale</div>
    <h1 class="section-title">Registrazione</h1>
    <p class="register-page__intro">
      Crea un account per iscriverti al sito. Successivamente potrai iscriverti come socio e richiedere prenotazioni.
    </p>

    <!-- Step 1: Crea account -->
    <div id="step-account" class="register-step">
      <h2 class="register-step__title">1. Crea il tuo account</h2>
      <AuthForm mode="register" />
    </div>

    <!-- Step 2: Completa profilo -->
    <div id="step-profile" class="register-step" hidden>
      <h2 class="register-step__title">2. Completa il tuo profilo</h2>
      <p class="register-step__desc">
        Inserisci i tuoi dati di base. Questi verranno usati per le tue richieste di prenotazione.
      </p>
      <form id="profile-form" novalidate>
        <div class="form-row">
          <div class="form-group">
            <label for="profile-nome">Nome *</label>
            <input type="text" id="profile-nome" name="nome" required />
          </div>
          <div class="form-group">
            <label for="profile-cognome">Cognome *</label>
            <input type="text" id="profile-cognome" name="cognome" required />
          </div>
        </div>
        <div class="form-group">
          <label for="profile-email">Email *</label>
          <input type="email" id="profile-email" name="email" required readonly />
          <span class="form-hint">Uguale all'email dell'account</span>
        </div>
        <div class="form-group">
          <label for="profile-telefono">Telefono</label>
          <input type="tel" id="profile-telefono" name="telefono" />
        </div>

        <div data-message hidden class="form-message"></div>

        <button type="submit" class="btn btn-primary register-step__submit">
          Completa registrazione
        </button>
      </form>
    </div>
  </div>
</SociLayout>

<script>
  import { createClient } from '@supabase/supabase-js';

  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );

  let currentUserId: string | null = null;
  let currentUserEmail: string | null = null;

  // === STEP 1: Registrazione account ===
  const authForm = document.getElementById('auth-form') as HTMLFormElement;
  const authError = document.getElementById('auth-error')!;
  const authSuccess = document.getElementById('auth-success')!;

  authForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    authError.hidden = true;
    authSuccess.hidden = true;

    const formData = new FormData(authForm);
    const email = formData.get('email') as string;
    const password = formData.get('password') as string;
    const passwordConfirm = formData.get('password_confirm') as string;

    if (password !== passwordConfirm) {
      authError.textContent = 'Le password non coincidono.';
      authError.hidden = false;
      return;
    }

    const submitBtn = authForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Creazione account...';
    submitBtn.disabled = true;

    const { data, error } = await supabase.auth.signUp({ email, password });

    if (error) {
      authError.textContent = 'Errore nella registrazione: ' + error.message;
      authError.hidden = false;
      submitBtn.textContent = 'Crea account';
      submitBtn.disabled = false;
      return;
    }

    if (data.session) {
      // Salva token nei cookie
      document.cookie = `sb-access-token=${data.session.access_token}; path=/; max-age=3600; SameSite=Lax`;
      document.cookie = `sb-refresh-token=${data.session.refresh_token}; path=/; max-age=604800; SameSite=Lax`;
      currentUserId = data.user?.id || null;
      currentUserEmail = email;

      // Passa allo step 2
      document.getElementById('step-account')!.hidden = true;
      document.getElementById('step-profile')!.hidden = false;

      // Pre-compila l'email
      const emailInput = document.getElementById('profile-email') as HTMLInputElement;
      if (emailInput) emailInput.value = email;
    } else {
      // Se la conferma email e' attiva
      authSuccess.textContent = 'Account creato! Controlla la tua email per confermare, poi accedi.';
      authSuccess.hidden = false;
      submitBtn.textContent = 'Crea account';
      submitBtn.disabled = false;
    }
  });

  // === STEP 2: Profilo ===
  const profileForm = document.getElementById('profile-form') as HTMLFormElement;

  profileForm.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!profileForm.checkValidity()) {
      profileForm.reportValidity();
      return;
    }

    const submitBtn = profileForm.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Salvataggio...';
    submitBtn.disabled = true;

    const formData = new FormData(profileForm);
    const profileData = {
      id: currentUserId,
      nome: formData.get('nome'),
      cognome: formData.get('cognome'),
      email: currentUserEmail,
      telefono: formData.get('telefono') || null,
    };

    const { error } = await supabase.from('profili').insert([profileData]);

    const msgEl = profileForm.querySelector('[data-message]') as HTMLElement;

    if (error) {
      msgEl.textContent = 'Errore nel salvataggio: ' + error.message;
      msgEl.className = 'form-message form-message--error';
      msgEl.hidden = false;
      submitBtn.textContent = 'Completa registrazione';
      submitBtn.disabled = false;
      return;
    }

    // Redirect alla dashboard
    window.location.href = '/soci/';
  });
</script>

<style>
  .register-page {
    max-width: 680px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .register-page__intro {
    margin-bottom: 2.5rem;
    color: var(--color-gray);
  }

  .register-step {
    margin-bottom: 3rem;
  }

  .register-step__title {
    font-size: 1.3rem;
    margin-bottom: 0.5rem;
  }

  .register-step__desc {
    color: var(--color-gray);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .register-step__submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .register-step__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-hint {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.8rem;
    color: var(--color-gray-light);
  }

  .form-message {
    margin-bottom: 1.5rem;
    padding: 1rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .form-message--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
  }
</style>
