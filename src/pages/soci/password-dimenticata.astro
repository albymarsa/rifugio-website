---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';

// Se l'utente e' gia' loggato, redirect alla dashboard
const accessToken = Astro.cookies.get('sb-access-token')?.value;
if (accessToken) {
  return Astro.redirect('/soci/');
}
---

<SociLayout title="Password dimenticata" showBackLink={false}>
  <div class="forgot-page">
    <div class="section-label">Area Personale</div>
    <h1 class="section-title">Password dimenticata</h1>
    <p class="forgot-page__intro">
      Inserisci l'email del tuo account. Riceverai un link per reimpostare la password.
    </p>

    <form id="forgot-form" class="forgot-form" novalidate>
      <div class="form-group">
        <label for="forgot-email">Email *</label>
        <input type="email" id="forgot-email" name="email" required autocomplete="email" />
      </div>

      <button type="submit" class="btn btn-primary forgot-form__submit">
        Invia link di reset
      </button>

      <div id="forgot-error" class="form-message form-message--error" hidden></div>
      <div id="forgot-success" class="form-message form-message--success" hidden></div>

      <div class="forgot-form__footer">
        <p>Ricordi la password? <a href="/soci/login">Accedi</a></p>
      </div>
    </form>
  </div>
</SociLayout>

<script>
  const form = document.getElementById('forgot-form') as HTMLFormElement;
  const errorDiv = document.getElementById('forgot-error')!;
  const successDiv = document.getElementById('forgot-success')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.hidden = true;
    successDiv.hidden = true;

    const formData = new FormData(form);
    const email = formData.get('email') as string;

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Invio in corso...';
    submitBtn.disabled = true;

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      const result = await res.json();

      if (!res.ok) {
        errorDiv.textContent = result.error || 'Errore. Riprova.';
        errorDiv.hidden = false;
        submitBtn.textContent = 'Invia link di reset';
        submitBtn.disabled = false;
        return;
      }

      successDiv.textContent = result.message;
      successDiv.hidden = false;
      form.querySelector('.form-group')!.setAttribute('hidden', '');
      submitBtn.hidden = true;
    } catch {
      errorDiv.textContent = 'Errore di connessione. Riprova.';
      errorDiv.hidden = false;
      submitBtn.textContent = 'Invia link di reset';
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .forgot-page {
    max-width: 440px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .forgot-page__intro {
    margin-bottom: 2.5rem;
    color: var(--color-gray);
  }

  .forgot-form__submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .forgot-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .forgot-form__footer {
    margin-top: 2rem;
    text-align: center;
  }

  .forgot-form__footer p {
    font-size: 0.9rem;
    color: var(--color-gray);
    max-width: none;
  }

  .forgot-form__footer a {
    color: var(--color-black);
    font-weight: 600;
    text-decoration: underline;
  }

  .form-message {
    margin-top: 1.5rem;
    padding: 1.2rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .form-message--success {
    background-color: #f0f7ec;
    color: #2d5016;
    border-left: 3px solid #2d5016;
  }

  .form-message--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
  }
</style>
