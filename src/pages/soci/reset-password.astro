---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';
import { createClient } from '@supabase/supabase-js';

// Gestione flusso PKCE: Supabase invia ?code=... nella query string
const code = Astro.url.searchParams.get('code');
let sessionTokens: { access_token: string; refresh_token: string } | null = null;

if (code) {
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_ANON_KEY
  );
  const { data, error } = await supabase.auth.exchangeCodeForSession(code);
  if (!error && data.session) {
    sessionTokens = {
      access_token: data.session.access_token,
      refresh_token: data.session.refresh_token,
    };
  }
}
---

<SociLayout title="Reimposta password" showBackLink={false}>
  <div class="reset-page">
    <div class="section-label">Area Personale</div>
    <h1 class="section-title">Reimposta password</h1>

    {sessionTokens && (
      <div
        id="pkce-tokens"
        data-access={sessionTokens.access_token}
        data-refresh={sessionTokens.refresh_token}
        hidden
      />
    )}

    <div id="reset-invalid" class="form-message form-message--error" hidden>
      Il link non è valido o è scaduto. <a href="/soci/password-dimenticata">Richiedi un nuovo link</a>.
    </div>

    <form id="reset-form" class="reset-form" novalidate hidden>
      <p class="reset-page__intro">
        Inserisci la tua nuova password.
      </p>

      <div class="form-group">
        <label for="reset-password">Nuova password *</label>
        <input
          type="password"
          id="reset-password"
          name="password"
          required
          minlength="6"
          autocomplete="new-password"
        />
        <span class="form-hint">Minimo 6 caratteri</span>
      </div>

      <div class="form-group">
        <label for="reset-password-confirm">Conferma nuova password *</label>
        <input
          type="password"
          id="reset-password-confirm"
          name="password_confirm"
          required
          minlength="6"
          autocomplete="new-password"
        />
      </div>

      <button type="submit" class="btn btn-primary reset-form__submit">
        Reimposta password
      </button>

      <div id="reset-error" class="form-message form-message--error" hidden></div>
      <div id="reset-success" class="form-message form-message--success" hidden></div>
    </form>
  </div>
</SociLayout>

<script>
  const form = document.getElementById('reset-form') as HTMLFormElement;
  const invalidDiv = document.getElementById('reset-invalid')!;
  const errorDiv = document.getElementById('reset-error')!;
  const successDiv = document.getElementById('reset-success')!;

  // Priorità 1: token ottenuti server-side dal flusso PKCE (?code=...)
  const pkceEl = document.getElementById('pkce-tokens');
  let accessToken = pkceEl?.dataset.access || null;
  let refreshToken = pkceEl?.dataset.refresh || null;

  // Priorità 2: fallback al flusso implicito (hash fragment)
  if (!accessToken || !refreshToken) {
    const hash = window.location.hash.substring(1);
    const params = new URLSearchParams(hash);
    accessToken = params.get('access_token');
    refreshToken = params.get('refresh_token');
    const type = params.get('type');
    if (type && type !== 'recovery') {
      accessToken = null;
      refreshToken = null;
    }
  }

  if (!accessToken || !refreshToken) {
    invalidDiv.hidden = false;
  } else {
    form.hidden = false;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorDiv.hidden = true;
    successDiv.hidden = true;

    const formData = new FormData(form);
    const password = formData.get('password') as string;
    const passwordConfirm = formData.get('password_confirm') as string;

    if (password !== passwordConfirm) {
      errorDiv.textContent = 'Le password non coincidono.';
      errorDiv.hidden = false;
      return;
    }

    if (password.length < 6) {
      errorDiv.textContent = 'La password deve avere almeno 6 caratteri.';
      errorDiv.hidden = false;
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    submitBtn.textContent = 'Aggiornamento...';
    submitBtn.disabled = true;

    try {
      const res = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          access_token: accessToken,
          refresh_token: refreshToken,
          password,
        }),
      });

      const result = await res.json();

      if (!res.ok) {
        errorDiv.textContent = result.error || 'Errore. Riprova.';
        errorDiv.hidden = false;
        submitBtn.textContent = 'Reimposta password';
        submitBtn.disabled = false;
        return;
      }

      successDiv.textContent = 'Password aggiornata! Reindirizzamento...';
      successDiv.hidden = false;
      form.querySelectorAll('.form-group').forEach(el => (el as HTMLElement).hidden = true);
      submitBtn.hidden = true;

      setTimeout(() => {
        window.location.href = '/soci/';
      }, 2000);
    } catch {
      errorDiv.textContent = 'Errore di connessione. Riprova.';
      errorDiv.hidden = false;
      submitBtn.textContent = 'Reimposta password';
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .reset-page {
    max-width: 440px;
    margin: 0 auto;
    padding-top: 2rem;
  }

  .reset-page__intro {
    margin-bottom: 2.5rem;
    color: var(--color-gray);
  }

  .reset-form__submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .reset-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-hint {
    display: block;
    margin-top: 0.3rem;
    font-size: 0.8rem;
    color: var(--color-gray);
  }

  .form-message {
    margin-top: 1.5rem;
    padding: 1.2rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .form-message--success {
    background-color: #f0f7ec;
    color: #2d5016;
    border-left: 3px solid #2d5016;
  }

  .form-message--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
  }

  .form-message a {
    color: inherit;
    font-weight: 700;
    text-decoration: underline;
  }
</style>
