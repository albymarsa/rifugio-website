---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';
import AdminTable from '../../components/soci/AdminTable.astro';
import { createClient } from '@supabase/supabase-js';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/soci/login');
}

// Il middleware ha gia' verificato che l'utente sia fondatore
// Carica tutti i soci
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

if (accessToken && refreshToken) {
  await supabase.auth.setSession({
    access_token: accessToken,
    refresh_token: refreshToken,
  });
}

const { data: allMembers, error } = await supabase
  .from('soci')
  .select('*')
  .order('cognome');
---

<SociLayout title="Gestione Soci">
  <div class="admin-page">
    <div class="admin-page__header">
      <div>
        <div class="section-label">Amministrazione</div>
        <h1 class="section-title">Gestione Soci</h1>
      </div>
      <a href="/soci/prenotazioni" class="btn btn-outline">
        Gestione Prenotazioni
      </a>
    </div>
    <p class="admin-page__intro">
      Elenco completo di tutti i soci dell'associazione.
    </p>

    {error && (
      <div class="alert alert--error">
        Errore nel caricamento dei dati. Riprova.
      </div>
    )}

    {allMembers && <AdminTable members={allMembers} />}
  </div>
</SociLayout>

<style>
  .admin-page {
    padding-top: 1rem;
  }

  .admin-page__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .admin-page__intro {
    margin-bottom: 2rem;
    color: var(--color-gray);
  }

  .alert--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }
</style>
