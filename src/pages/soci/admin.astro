---
export const prerender = false;

import SociLayout from '../../layouts/SociLayout.astro';
import AdminTable from '../../components/soci/AdminTable.astro';
import { createClient } from '@supabase/supabase-js';

const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/soci/login');
}

// Il middleware ha gia' verificato che l'utente sia fondatore
// Carica tutti i soci
const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);

const accessToken = Astro.cookies.get('sb-access-token')?.value;
const refreshToken = Astro.cookies.get('sb-refresh-token')?.value;

if (accessToken && refreshToken) {
  await supabase.auth.setSession({
    access_token: accessToken,
    refresh_token: refreshToken,
  });
}

// Carica solo i campi necessari per la visualizzazione (NO PII sensibili come CF, documento)
const { data: allMembers, error } = await supabase
  .from('soci')
  .select('id, nome, cognome, email, telefono, tipo_socio, created_at')
  .order('cognome');
---

<SociLayout title="Gestione Soci">
  <div class="admin-page">
    <div class="admin-page__header">
      <div>
        <div class="section-label">Amministrazione</div>
        <h1 class="section-title">Gestione Soci</h1>
      </div>
      <a href="/soci/prenotazioni" class="btn btn-outline">
        Gestione Prenotazioni
      </a>
    </div>
    <p class="admin-page__intro">
      Elenco completo di tutti i soci dell'associazione.
    </p>

    {allMembers && allMembers.length > 0 && (
      <div class="admin-page__export">
        <label for="export-year" class="admin-page__export-label">Esporta soci per anno:</label>
        <select id="export-year" class="admin-page__export-select">
          {[...new Set((allMembers || []).map((m: any) => new Date(m.created_at).getFullYear()))].sort((a: number, b: number) => b - a).map((year: number) => (
            <option value={year}>{year}</option>
          ))}
        </select>
        <button id="export-soci-btn" class="btn btn-outline admin-page__export-btn">
          Esporta Excel
        </button>
      </div>
    )}

    {error && (
      <div class="alert alert--error">
        Errore nel caricamento dei dati. Riprova.
      </div>
    )}

    {allMembers && <AdminTable members={allMembers} />}
  </div>
</SociLayout>

<script>
  import * as XLSX from 'xlsx';

  const exportBtn = document.getElementById('export-soci-btn');
  const yearSelect = document.getElementById('export-year') as HTMLSelectElement;

  if (exportBtn && yearSelect) {
    exportBtn.addEventListener('click', async () => {
      const year = yearSelect.value;
      (exportBtn as HTMLButtonElement).textContent = 'Caricamento...';
      (exportBtn as HTMLButtonElement).disabled = true;

      try {
        const res = await fetch(`/api/soci/export?year=${year}`);
        if (!res.ok) {
          const result = await res.json();
          alert(result.error || 'Errore nel caricamento dei dati.');
          return;
        }

        const filtered = await res.json();

        if (filtered.length === 0) {
          alert('Nessun socio trovato per l\'anno ' + year);
          return;
        }

        const rows = filtered.map((s: any) => ({
          'Cognome': s.cognome || '',
          'Nome': s.nome || '',
          'Email': s.email || '',
          'Telefono': s.telefono || '',
          'Codice Fiscale': s.codice_fiscale || '',
          'Data Nascita': s.data_nascita || '',
          'Luogo Nascita': s.luogo_nascita || '',
          'Indirizzo Residenza': s.indirizzo_residenza || '',
          'Tipo Documento': s.tipo_documento || '',
          'Numero Documento': s.numero_documento || '',
          'Tipo Socio': s.tipo_socio || '',
          'Data Iscrizione': s.created_at ? new Date(s.created_at).toLocaleDateString('it-IT') : '',
        }));

        const ws = XLSX.utils.json_to_sheet(rows);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, 'Soci');

        // Auto-width colonne
        const colWidths = Object.keys(rows[0]).map((key) => ({
          wch: Math.max(key.length, ...rows.map((r: any) => String(r[key]).length)) + 2,
        }));
        ws['!cols'] = colWidths;

        XLSX.writeFile(wb, `soci_${year}.xlsx`);
      } catch {
        alert('Errore di connessione. Riprova.');
      } finally {
        (exportBtn as HTMLButtonElement).textContent = 'Esporta Excel';
        (exportBtn as HTMLButtonElement).disabled = false;
      }
    });
  }
</script>

<style>
  .admin-page {
    padding-top: 1rem;
  }

  .admin-page__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .admin-page__intro {
    margin-bottom: 1.5rem;
    color: var(--color-gray);
  }

  .admin-page__export {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .admin-page__export-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-gray);
  }

  .admin-page__export-select {
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--color-border);
    font-size: 0.85rem;
    font-family: var(--font-main);
    background: var(--color-white);
  }

  .admin-page__export-select:focus {
    outline: none;
    border-color: var(--color-black);
  }

  .admin-page__export-btn {
    padding: 0.5rem 1.2rem;
    font-size: 0.75rem;
  }

  .alert--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
    padding: 1rem 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }
</style>
