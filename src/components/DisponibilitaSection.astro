---
import CalendarioDisponibilita from './CalendarioDisponibilita.astro';
---

<section class="disponibilita-section" id="disponibilita">
  <div class="container">
    <div class="disponibilita-section__grid">
      <div class="disponibilita-section__calendar-wrap">
        <CalendarioDisponibilita />
      </div>

      <div class="disponibilita-section__info">
        <h2 class="section-title">Verifica disponibilità</h2>
        <p class="disponibilita-section__text">
          Il rifugio si prenota per intero: 25 posti letto. Controlla quando è libero e, se ti interessa, procedi con la richiesta. Per informazioni o richieste particolari scrivi a <a href="mailto:info@rifugiorosmini.it">info@rifugiorosmini.it</a>.
        </p>
        <div class="disponibilita-section__cta">
          <p>Vuoi prenotare? Serve un account socio.</p>
          <a href="/soci/login" class="btn btn-primary">Accedi o registrati</a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .disponibilita-section {
    padding: 4rem 0;
    background: var(--color-off-white);
  }

  .disponibilita-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  .disponibilita-section__calendar-wrap {
    display: flex;
    justify-content: center;
  }

  .disponibilita-section__info {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
  }

  .disponibilita-section__text {
    color: var(--color-gray);
    margin-bottom: 1.5rem;
  }

  .disponibilita-section__cta p {
    margin-bottom: 0.8rem;
    color: var(--color-gray);
  }

  @media (min-width: 900px) {
    .disponibilita-section__grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: 3.5rem;
    }

    .disponibilita-section__calendar-wrap {
      justify-content: flex-end;
    }

    .disponibilita-section__info {
      margin: 0;
      text-align: left;
    }

    .disponibilita-section__info .section-title {
      text-align: left;
    }
  }
</style>
