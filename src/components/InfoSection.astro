---
import content from '../data/content.json';
const { label, title, paragraphs, contact_email, details } = content.info;
---

<section class="section">
  <div class="container info">
    <span class="section-label">{label}</span>
    <h2 class="section-title">{title}</h2>
    <div class="info__content">
      <div class="info__text">
        {paragraphs.map((p: string) => <p class="mt-2">{p}</p>)}
        {contact_email && (
          <p class="mt-2">
            Per richieste particolari scrivi a <a href={`mailto:${contact_email}`}>{contact_email}</a>.
          </p>
        )}
      </div>
      <div class="info__details">
        {details.map((d: { label: string; value: string }) => (
          <div class="info__detail">
            <span class="info__detail-label">{d.label}</span>
            <span class="info__detail-value">{d.value}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .info__content {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 4rem;
    align-items: start;
    margin-top: 1rem;
  }

  .info__text p {
    font-size: 1.05rem;
  }

  .info__details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 2rem;
    background-color: var(--color-off-white);
  }

  .info__detail {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .info__detail:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .info__detail-label {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .info__detail-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-black);
  }

  @media (max-width: 768px) {
    .info__content {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
