---
// Componente calendario disponibilità - interamente client-side
---

<div class="calendario" id="calendario-disponibilita">
  <div class="calendario__header">
    <button class="btn btn-outline calendario__nav" id="cal-prev" aria-label="Mese precedente">&larr;</button>
    <h3 class="calendario__title" id="cal-title">Caricamento...</h3>
    <button class="btn btn-outline calendario__nav" id="cal-next" aria-label="Mese successivo">&rarr;</button>
  </div>

  <div class="calendario__legend">
    <span class="calendario__legend-item">
      <span class="calendario__dot calendario__dot--green"></span> Libero
    </span>
    <span class="calendario__legend-item">
      <span class="calendario__dot calendario__dot--red"></span> Occupato
    </span>
    <span class="calendario__legend-item">
      <span class="calendario__dot calendario__dot--gray"></span> Passato
    </span>
    <span class="calendario__legend-item">
      <span class="calendario__dot calendario__dot--closed"></span> Chiuso
    </span>
  </div>

  <div class="calendario__weekdays">
    <span>Lun</span>
    <span>Mar</span>
    <span>Mer</span>
    <span>Gio</span>
    <span>Ven</span>
    <span>Sab</span>
    <span>Dom</span>
  </div>

  <div class="calendario__grid" id="cal-grid"></div>
</div>

<script>
  const MESI = [
    'Gennaio', 'Febbraio', 'Marzo', 'Aprile', 'Maggio', 'Giugno',
    'Luglio', 'Agosto', 'Settembre', 'Ottobre', 'Novembre', 'Dicembre'
  ];

  const cache = new Map<string, { occupazione: Record<string, number>; capacita: number }>();
  const today = new Date();
  const todayStr = `${today.getFullYear()}-${String(today.getMonth() + 1).padStart(2, '0')}-${String(today.getDate()).padStart(2, '0')}`;

  let currentYear = today.getFullYear();
  let currentMonth = today.getMonth(); // 0-indexed

  const titleEl = document.getElementById('cal-title')!;
  const gridEl = document.getElementById('cal-grid')!;
  const prevBtn = document.getElementById('cal-prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('cal-next') as HTMLButtonElement;

  async function fetchOccupancy(year: number, month: number) {
    const key = `${year}-${month + 1}`;
    if (cache.has(key)) return cache.get(key)!;

    const res = await fetch(`/api/disponibilita?anno=${year}&mese=${month + 1}`);
    if (!res.ok) return { occupazione: {}, capacita: 25 };

    const data = await res.json();
    cache.set(key, data);
    return data;
  }

  function renderCalendar(year: number, month: number, occupazione: Record<string, number>, capacita: number) {
    titleEl.textContent = `${MESI[month]} ${year}`;
    gridEl.innerHTML = '';

    // Primo giorno del mese: 0=Lun, 6=Dom (convenzione italiana)
    const firstDay = new Date(year, month, 1).getDay();
    const startOffset = firstDay === 0 ? 6 : firstDay - 1;

    // Giorni nel mese
    const daysInMonth = new Date(year, month + 1, 0).getDate();

    // Celle vuote di offset
    for (let i = 0; i < startOffset; i++) {
      const empty = document.createElement('div');
      empty.className = 'calendario__day calendario__day--empty';
      gridEl.appendChild(empty);
    }

    // Celle dei giorni
    for (let day = 1; day <= daysInMonth; day++) {
      const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
      const occupied = occupazione[dateStr] || 0;
      const isPast = dateStr < todayStr;
      const isClosed = month + 1 < 6 || month + 1 > 10;

      const cell = document.createElement('div');
      cell.className = 'calendario__day';

      if (isPast) {
        cell.classList.add('calendario__day--past');
      } else if (isClosed) {
        cell.classList.add('calendario__day--closed');
      } else if (occupied > 0) {
        cell.classList.add('calendario__day--red');
      } else {
        cell.classList.add('calendario__day--green');
      }

      const dayNum = document.createElement('span');
      dayNum.className = 'calendario__day-num';
      dayNum.textContent = String(day);
      cell.appendChild(dayNum);

      if (!isPast && !isClosed) {
        const info = document.createElement('span');
        info.className = 'calendario__day-info';
        info.textContent = occupied > 0 ? 'Occupato' : 'Libero';
        cell.appendChild(info);

        // Click per auto-compilare data arrivo
        if (occupied === 0) {
          cell.style.cursor = 'pointer';
          cell.addEventListener('click', () => {
            const arrivoInput = document.getElementById('data_arrivo') as HTMLInputElement;
            if (arrivoInput) {
              arrivoInput.value = dateStr;
              arrivoInput.dispatchEvent(new Event('change', { bubbles: true }));
              arrivoInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
          });
        }
      } else if (isClosed) {
        const info = document.createElement('span');
        info.className = 'calendario__day-info';
        info.textContent = 'Chiuso';
        cell.appendChild(info);
      }

      gridEl.appendChild(cell);
    }

    // Aggiorna stato bottoni navigazione
    prevBtn.disabled = year === today.getFullYear() && month === today.getMonth();
    const maxDate = new Date(today.getFullYear(), today.getMonth() + 6, 1);
    nextBtn.disabled = year > maxDate.getFullYear() || (year === maxDate.getFullYear() && month >= maxDate.getMonth());
  }

  async function loadMonth(year: number, month: number) {
    gridEl.innerHTML = '<div class="calendario__loading">Caricamento...</div>';
    const data = await fetchOccupancy(year, month);
    renderCalendar(year, month, data.occupazione, data.capacita);
  }

  prevBtn.addEventListener('click', () => {
    currentMonth--;
    if (currentMonth < 0) {
      currentMonth = 11;
      currentYear--;
    }
    loadMonth(currentYear, currentMonth);
  });

  nextBtn.addEventListener('click', () => {
    currentMonth++;
    if (currentMonth > 11) {
      currentMonth = 0;
      currentYear++;
    }
    loadMonth(currentYear, currentMonth);
  });

  // Carica il mese corrente
  loadMonth(currentYear, currentMonth);
</script>

<style is:global>
  .calendario {
    margin-bottom: 3rem;
    max-width: 680px;
  }

  .calendario__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.2rem;
  }

  .calendario__title {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
  }

  .calendario__nav {
    padding: 0.4rem 0.8rem;
    font-size: 0.85rem;
    min-width: 40px;
  }

  .calendario__nav:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .calendario__legend {
    display: flex;
    gap: 1.2rem;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .calendario__legend-item {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: var(--color-gray);
  }

  .calendario__dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 2px;
  }

  .calendario__dot--green {
    background: #e8f5e0;
    border: 1px solid #2d5016;
  }

  .calendario__dot--red {
    background: #fde8e8;
    border: 1px solid #9b1c1c;
  }

  .calendario__dot--gray {
    background: var(--color-off-white);
    border: 1px solid var(--color-border);
  }

  .calendario__dot--closed {
    background: #d9d9d9;
    border: 1px solid #8a8a8a;
  }

  .calendario__weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: 2px;
  }

  .calendario__weekdays span {
    text-align: center;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-gray);
    padding: 0.4rem 0;
  }

  .calendario__grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    min-height: 200px;
  }

  .calendario__day {
    padding: 0.5rem 0.3rem;
    text-align: center;
    border-radius: 3px;
    transition: opacity 0.15s;
  }

  .calendario__day:not(.calendario__day--empty):not(.calendario__day--past):hover {
    opacity: 0.8;
  }

  .calendario__day--empty {
    background: transparent;
  }

  .calendario__day--past {
    background: var(--color-off-white);
    color: var(--color-gray-light);
  }

  .calendario__day--green {
    background: #e8f5e0;
    border: 1px solid #c5e1b5;
  }

  .calendario__day--red {
    background: #fde8e8;
    border: 1px solid #f0b8b8;
  }

  .calendario__day--closed {
    background: #d9d9d9;
    border: 1px solid #b0b0b0;
    color: #5a5a5a;
    cursor: default;
  }

  .calendario__day-num {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    line-height: 1.4;
  }

  .calendario__day-info {
    display: block;
    font-size: 0.6rem;
    color: var(--color-gray);
    line-height: 1.2;
  }

  .calendario__loading {
    grid-column: 1 / -1;
    text-align: center;
    padding: 2rem;
    color: var(--color-gray);
    font-size: 0.9rem;
  }

  @media (max-width: 768px) {
    .calendario__day {
      padding: 0.4rem 0.15rem;
    }

    .calendario__day-num {
      font-size: 0.8rem;
    }

    .calendario__day-info {
      display: none;
    }

    .calendario__legend {
      gap: 0.8rem;
    }
  }
</style>
