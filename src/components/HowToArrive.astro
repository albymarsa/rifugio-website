---
import content from '../data/content.json';
const { label, title, steps } = content.directions;
---

<section class="section section--alt">
  <div class="container">
    <span class="section-label">{label}</span>
    <h2 class="section-title">{title}</h2>
    <div class="arrive__grid">
      {steps.map((step: { number: string; heading: string; text: string; detail?: string }) => (
        <div class="arrive__step">
          <span class="arrive__number">{step.number}</span>
          <h3>{step.heading}</h3>
          <p>{step.text}</p>
          {step.detail && (
            <p style="margin-top: 0.8rem; font-size: 0.9rem; color: var(--color-gray);">
              {step.detail}
            </p>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .arrive__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem;
    margin-top: 2rem;
  }

  .arrive__step {
    position: relative;
  }

  .arrive__number {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-border);
    line-height: 1;
    display: block;
    margin-bottom: 1rem;
  }

  .arrive__step h3 {
    margin-bottom: 0.8rem;
    font-size: 1.1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .arrive__step p {
    font-size: 0.95rem;
    color: var(--color-gray);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .arrive__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }
</style>
