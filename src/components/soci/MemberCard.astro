---
interface Props {
  member: {
    id: string;
    nome: string;
    cognome: string;
    email: string;
    telefono?: string;
    data_nascita?: string;
    luogo_nascita?: string;
    codice_fiscale?: string;
    indirizzo_residenza?: string;
    tipo_documento?: string;
    numero_documento?: string;
    tipo_socio: string;
    created_at: string;
  };
  showEdit?: boolean;
}

const { member, showEdit = true } = Astro.props;

const tipoDocLabels: Record<string, string> = {
  carta_identita: "Carta d'identita",
  patente: 'Patente',
  passaporto: 'Passaporto',
};

function formatDate(dateStr?: string): string {
  if (!dateStr) return '—';
  try {
    return new Date(dateStr).toLocaleDateString('it-IT', {
      day: '2-digit',
      month: 'long',
      year: 'numeric',
    });
  } catch {
    return dateStr;
  }
}
---

<div class="member-card" data-member-id={member.id}>
  <div class="member-card__header">
    <div>
      <h3 class="member-card__name">{member.nome} {member.cognome}</h3>
      <span class="member-card__badge">
        {member.tipo_socio === 'fondatore' ? 'Socio fondatore' : 'Socio ordinario'}
      </span>
    </div>
    {showEdit && (
      <button class="btn btn-outline member-card__edit" data-edit={member.id}>
        Modifica
      </button>
    )}
  </div>

  <div class="member-card__body">
    <div class="member-card__grid">
      <div class="member-card__field">
        <span class="member-card__label">Email</span>
        <span class="member-card__value">{member.email}</span>
      </div>
      <div class="member-card__field">
        <span class="member-card__label">Telefono</span>
        <span class="member-card__value">{member.telefono || '—'}</span>
      </div>
      <div class="member-card__field">
        <span class="member-card__label">Data di nascita</span>
        <span class="member-card__value">{formatDate(member.data_nascita)}</span>
      </div>
      <div class="member-card__field">
        <span class="member-card__label">Luogo di nascita</span>
        <span class="member-card__value">{member.luogo_nascita || '—'}</span>
      </div>
      <div class="member-card__field">
        <span class="member-card__label">Codice fiscale</span>
        <span class="member-card__value">{member.codice_fiscale || '—'}</span>
      </div>
      <div class="member-card__field">
        <span class="member-card__label">Indirizzo</span>
        <span class="member-card__value">{member.indirizzo_residenza || '—'}</span>
      </div>
      {(member.tipo_documento || member.numero_documento) && (
        <>
          <div class="member-card__field">
            <span class="member-card__label">Tipo documento</span>
            <span class="member-card__value">
              {member.tipo_documento ? tipoDocLabels[member.tipo_documento] || member.tipo_documento : '—'}
            </span>
          </div>
          <div class="member-card__field">
            <span class="member-card__label">Numero documento</span>
            <span class="member-card__value">{member.numero_documento || '—'}</span>
          </div>
        </>
      )}
    </div>
    <div class="member-card__meta">
      Registrato il {formatDate(member.created_at)}
    </div>
  </div>
</div>

<style>
  .member-card {
    border: 1px solid var(--color-border);
    padding: 2rem;
    margin-bottom: 1.5rem;
    background: var(--color-white);
  }

  .member-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .member-card__name {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }

  .member-card__badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: #f0f7ec;
    padding: 0.2rem 0.6rem;
  }

  .member-card__edit {
    padding: 0.5rem 1.2rem;
    font-size: 0.75rem;
  }

  .member-card__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }

  .member-card__field {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .member-card__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .member-card__value {
    font-size: 0.95rem;
    color: var(--color-dark);
  }

  .member-card__meta {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    font-size: 0.8rem;
    color: var(--color-gray-light);
  }

  @media (max-width: 768px) {
    .member-card {
      padding: 1.5rem;
    }

    .member-card__header {
      flex-direction: column;
      gap: 1rem;
    }

    .member-card__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
