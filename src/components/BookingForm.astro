<!-- L'URL dello script Google va inserito qui sotto -->
<!-- Segui le istruzioni nel README per ottenere l'URL -->
<form id="booking-form" class="booking-form" novalidate>
  <div class="form-row">
    <div class="form-group">
      <label for="nome">Nome e Cognome *</label>
      <input type="text" id="nome" name="nome" required />
    </div>
    <div class="form-group">
      <label for="email">Email *</label>
      <input type="email" id="email" name="email" required />
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="data_arrivo">Data arrivo *</label>
      <input type="date" id="data_arrivo" name="data_arrivo" required />
    </div>
    <div class="form-group">
      <label for="data_partenza">Data partenza *</label>
      <input type="date" id="data_partenza" name="data_partenza" required />
    </div>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="persone">Numero persone *</label>
      <input type="number" id="persone" name="persone" min="1" max="25" required />
    </div>
    <div class="form-group">
      <label for="telefono">Telefono</label>
      <input type="tel" id="telefono" name="telefono" />
    </div>
  </div>

  <div class="form-group">
    <label for="note">Note aggiuntive</label>
    <textarea id="note" name="note" placeholder="Esigenze particolari, orario arrivo previsto, ecc."></textarea>
  </div>

  <div class="form-note">
    <p>* Campi obbligatori. La prenotazione non è confermata fino a quando non riceverai una nostra email di conferma (entro 48 ore).</p>
  </div>

  <button type="submit" class="btn btn-primary booking-form__submit">
    Invia richiesta
  </button>

  <!-- Messaggi di stato -->
  <div id="form-success" class="form-message form-message--success" hidden>
    Richiesta inviata! Ti risponderemo entro 48 ore all'indirizzo email indicato.
  </div>
  <div id="form-error" class="form-message form-message--error" hidden>
    Si è verificato un errore. Riprova o contattaci direttamente via email.
  </div>
</form>

<script>
  const GOOGLE_SCRIPT_URL = ''; // <-- Inserire qui l'URL del Google Apps Script

  const form = document.getElementById('booking-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Validazione base
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const submitBtn = form.querySelector('.booking-form__submit') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Invio in corso...';
    submitBtn.disabled = true;

    // Nascondi messaggi precedenti
    successMsg.hidden = true;
    errorMsg.hidden = true;

    // Raccogli dati
    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    if (!GOOGLE_SCRIPT_URL) {
      // Se l'URL non è configurato, mostra comunque il successo (per demo)
      console.warn('Google Apps Script URL non configurato. Dati form:', data);
      successMsg.hidden = false;
      form.reset();
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
      return;
    }

    try {
      await fetch(GOOGLE_SCRIPT_URL, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      // Con mode: 'no-cors' non possiamo leggere la risposta,
      // ma se non c'è errore di rete, consideriamo l'invio riuscito
      successMsg.hidden = false;
      form.reset();
    } catch {
      errorMsg.hidden = false;
    } finally {
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .booking-form {
    max-width: 680px;
  }

  .booking-form__submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .booking-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .form-note {
    margin-bottom: 1.5rem;
  }

  .form-note p {
    font-size: 0.85rem;
    color: var(--color-gray);
    max-width: none;
  }

  .form-message {
    margin-top: 1.5rem;
    padding: 1.2rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .form-message--success {
    background-color: #f0f7ec;
    color: #2d5016;
    border-left: 3px solid #2d5016;
  }

  .form-message--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
  }
</style>
