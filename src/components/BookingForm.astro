---
interface Props {
  profilo: {
    nome: string;
    cognome: string;
    email: string;
    telefono?: string;
  };
}

const { profilo } = Astro.props;
---

<form id="booking-form" class="booking-form" novalidate>
  <div class="booking-form__requester">
    <span class="booking-form__label">Prenotazione a nome di</span>
    <span class="booking-form__name">{profilo.nome} {profilo.cognome}</span>
    <span class="booking-form__email">{profilo.email}{profilo.telefono ? ` — ${profilo.telefono}` : ''}</span>
  </div>

  <div class="form-row">
    <div class="form-group">
      <label for="data_arrivo">Data arrivo *</label>
      <input type="date" id="data_arrivo" name="data_arrivo" required />
    </div>
    <div class="form-group">
      <label for="data_partenza">Data partenza *</label>
      <input type="date" id="data_partenza" name="data_partenza" required />
    </div>
  </div>

  <div class="booking-form__info">
    <p>La prenotazione è sempre per l'intera struttura (25 posti letto). Per richieste particolari scrivi a info@rifugiorosmini.it.</p>
  </div>

  <div class="form-group">
    <label for="note">Note aggiuntive</label>
    <textarea id="note" name="note" placeholder="Esigenze particolari, orario arrivo previsto, ecc."></textarea>
  </div>

  <div class="form-group form-group--checkbox">
    <label class="checkbox-label">
      <input type="checkbox" name="privacy_consent" required />
      <span>
        Ho letto l'<a href="/privacy" target="_blank">informativa sulla privacy</a> e acconsento al trattamento dei dati personali per la gestione della prenotazione. *
      </span>
    </label>
  </div>

  <div class="form-note">
    <p>* Campi obbligatori. La prenotazione non è confermata fino a quando non riceverai una nostra email di conferma (entro 48 ore).</p>
  </div>

  <button type="submit" class="btn btn-primary booking-form__submit">
    Invia richiesta
  </button>

  <!-- Messaggi di stato -->
  <div id="form-success" class="form-message form-message--success" hidden>
    Richiesta inviata! Ti risponderemo entro 48 ore all'indirizzo email indicato.
  </div>
  <div id="form-error" class="form-message form-message--error" hidden></div>
</form>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg = document.getElementById('form-error')!;

  const arrivoInput = document.getElementById('data_arrivo') as HTMLInputElement;
  const partenzaInput = document.getElementById('data_partenza') as HTMLInputElement;

  // Stagione: il rifugio è aperto solo giugno–ottobre.
  const isClosedDate = (s: string) => {
    if (!s) return false;
    const m = Number(s.slice(5, 7));
    return m < 6 || m > 10;
  };
  const prevDay = (s: string) => {
    const [y, m, d] = s.split('-').map(Number);
    const p = new Date(y, m - 1, d - 1);
    return `${p.getFullYear()}-${String(p.getMonth() + 1).padStart(2, '0')}-${String(p.getDate()).padStart(2, '0')}`;
  };
  const validateSeason = () => {
    const a = arrivoInput.value;
    const p = partenzaInput.value;
    const msg = 'Il rifugio è chiuso da novembre a maggio. Seleziona date tra giugno e ottobre.';
    if (a && isClosedDate(a)) {
      arrivoInput.setCustomValidity(msg);
    } else {
      arrivoInput.setCustomValidity('');
    }
    if (p && isClosedDate(prevDay(p))) {
      partenzaInput.setCustomValidity(msg);
    } else {
      partenzaInput.setCustomValidity('');
    }
  };
  arrivoInput.addEventListener('change', validateSeason);
  partenzaInput.addEventListener('change', validateSeason);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    const submitBtn = form.querySelector('.booking-form__submit') as HTMLButtonElement;
    const originalText = submitBtn.textContent;
    submitBtn.textContent = 'Invio in corso...';
    submitBtn.disabled = true;

    successMsg.hidden = true;
    errorMsg.hidden = true;

    const formData = new FormData(form);

    try {
      const res = await fetch('/api/prenotazioni', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          data_arrivo: formData.get('data_arrivo'),
          data_partenza: formData.get('data_partenza'),
          note: formData.get('note') || null,
        }),
      });

      const result = await res.json().catch(() => ({}));

      if (!res.ok) {
        errorMsg.textContent = result.error || 'Si è verificato un errore. Riprova o contattaci direttamente via email.';
        errorMsg.hidden = false;
        return;
      }

      successMsg.hidden = false;
      form.reset();
    } catch {
      errorMsg.textContent = 'Errore di connessione. Riprova.';
      errorMsg.hidden = false;
    } finally {
      submitBtn.textContent = originalText;
      submitBtn.disabled = false;
    }
  });
</script>

<style>
  .booking-form {
    max-width: 680px;
  }

  .booking-form__requester {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding: 1.5rem;
    background: var(--color-off-white);
    margin-bottom: 2rem;
    border-left: 3px solid var(--color-accent);
  }

  .booking-form__label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-gray);
  }

  .booking-form__name {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-black);
  }

  .booking-form__email {
    font-size: 0.9rem;
    color: var(--color-gray);
  }

  .booking-form__submit {
    width: 100%;
    padding: 1rem;
    font-size: 0.95rem;
    margin-top: 0.5rem;
  }

  .booking-form__submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .booking-form__info {
    padding: 1rem 1.5rem;
    background: #f0f7ec;
    border-left: 3px solid var(--color-accent);
    margin-bottom: 1.5rem;
  }

  .booking-form__info p {
    font-size: 0.95rem;
    color: var(--color-black);
    margin: 0;
    max-width: none;
  }

  .form-note {
    margin-bottom: 1.5rem;
  }

  .form-note p {
    font-size: 0.85rem;
    color: var(--color-gray);
    max-width: none;
  }

  .form-message {
    margin-top: 1.5rem;
    padding: 1.2rem 1.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .form-message--success {
    background-color: #f0f7ec;
    color: #2d5016;
    border-left: 3px solid #2d5016;
  }

  .form-message--error {
    background-color: #fdf0f0;
    color: #9b1c1c;
    border-left: 3px solid #9b1c1c;
  }

  .form-group--checkbox {
    margin-top: 0.5rem;
    margin-bottom: 1rem;
  }

  .checkbox-label {
    display: flex;
    gap: 0.6rem;
    align-items: flex-start;
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--color-dark);
    cursor: pointer;
    text-transform: none;
    letter-spacing: normal;
    font-weight: 400;
  }

  .checkbox-label input[type="checkbox"] {
    margin-top: 0.25rem;
    flex-shrink: 0;
    width: 16px;
    height: 16px;
  }

  .checkbox-label a {
    color: var(--color-black);
    font-weight: 600;
    text-decoration: underline;
  }
</style>
